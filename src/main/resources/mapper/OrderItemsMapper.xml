<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.movie_booking_backend.mapper.OrderItemsMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.movie_booking_backend.model.domain.OrderItems">
        <id column="id" property="id" />
        <result column="order_id" property="orderId" />
        <result column="price" property="price" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="is_deleted" property="deleted" />
        <result column="seat_id" property="seatId" />
    </resultMap>
    <insert id="insertBatchSomeColumn">
        INSERT INTO order_items (order_id, seat_id,  price, created_at, updated_at, is_deleted)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.orderId}, #{item.seatId},  #{item.price}, #{item.createdAt}, #{item.updatedAt}, 0)
        </foreach>
    </insert>
    <select id="findSeatIdsBySessionId" resultType="java.lang.Long">
        SELECT oi.seat_id
        FROM order_items oi
                 JOIN orders o ON oi.order_id = o.id
        WHERE o.session_id = #{sessionId}
          AND o.is_deleted = 0
          AND oi.is_deleted = 0
    </select>

</mapper>
