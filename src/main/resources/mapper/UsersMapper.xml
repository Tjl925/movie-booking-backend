<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.movie_booking_backend.mapper.UsersMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.example.movie_booking_backend.model.domain.Users">
        <id column="id" property="id" />
        <result column="username" property="username" />
        <result column="password" property="password" />
        <result column="open_id" property="openId" />
        <result column="email" property="email" />
        <result column="phone" property="phone" />
        <result column="avatar" property="avatar" />
        <result column="role_id" property="roleId" />
        <result column="status" property="status" />
        <result column="last_login" property="lastLogin" />
        <result column="login_count" property="loginCount" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="is_deleted" property="deleted" />
    </resultMap>

    <!-- 根据ID查找未删除的用户 -->
    <select id="selectByIdAndIsDeletedFalse" resultMap="BaseResultMap">
        SELECT id, username, password, open_id, email, phone, avatar, role_id, status, last_login, login_count, created_at, updated_at, is_deleted
        FROM users
        WHERE id = #{id} AND is_deleted = 0
    </select>

    <!-- 根据分组ID查询用户列表（分页） -->
    <select id="selectUsersByGroupId" resultMap="BaseResultMap">
        SELECT
        u.id, u.username, u.password, u.open_id, u.email, u.phone, u.avatar, u.role_id, u.status, u.last_login, u.login_count, u.created_at, u.updated_at, u.is_deleted
        FROM users u
        JOIN user_group_relations r ON u.id = r.user_id
        WHERE r.group_id = #{groupId} AND u.is_deleted = 0 AND r.is_deleted = 0
    </select>

</mapper>
